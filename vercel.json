{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/", "destination": "/ko", "permanent": false },
    { "source": "/:lang(ko|en)/moves/fast", "destination": "/:lang/fast", "permanent": true },
    { "source": "/:lang(ko|en)/moves/charged", "destination": "/:lang", "permanent": true }
  ]
}
