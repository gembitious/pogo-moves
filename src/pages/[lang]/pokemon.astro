---
import Base from '@/layouts/Base.astro'
import PokemonExplorer from '@/components/PokemonExplorer.tsx'
import { fastMoves, chargedMoves } from '@/lib/moves'
import { getDictionary, type Locale } from '@/lib/i18n'

export function getStaticPaths() {
  return [{ params: { lang: 'ko' } }, { params: { lang: 'en' } }]
}

const lang = Astro.params.lang as Locale
const dict = getDictionary(lang)
---

<Base locale={lang} title={dict.nav.pokemon} description={dict.meta.desc.pokemon}>
  <PokemonExplorer client:load locale={lang} dict={dict} fast={fastMoves} charged={chargedMoves} />
</Base>
