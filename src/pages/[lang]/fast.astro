---
import Base from '@/layouts/Base.astro'
import MoveExplorer from '@/components/MoveExplorer.tsx'
import { fastMoves } from '@/lib/moves'
import { getDictionary, type Locale } from '@/lib/i18n'

export function getStaticPaths() {
  return [{ params: { lang: 'ko' } }, { params: { lang: 'en' } }]
}

const lang = Astro.params.lang as Locale
const dict = getDictionary(lang)
---

<Base locale={lang} title={dict.nav.fast}>
  <MoveExplorer client:load category="fast" locale={lang} dict={dict} moves={fastMoves} />
</Base>
