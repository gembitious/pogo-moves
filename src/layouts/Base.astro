---
import '@/styles/global.css'
import Nav from '@/components/Nav.astro'
import { getDictionary } from '@/lib/i18n'

interface Props {
  locale: string
  title?: string
}

const { locale, title } = Astro.props
const dict = getDictionary(locale)
const pageTitle = title ? `${title} · ${dict.meta.title}` : dict.meta.title

// Language alternates for the same page (path without its locale segment).
const rest = Astro.url.pathname.replace(/^\/(ko|en)(?=\/|$)/, '')
const canonical = new URL(`/${locale}${rest}`, Astro.site)
const koUrl = new URL(`/ko${rest}`, Astro.site)
const enUrl = new URL(`/en${rest}`, Astro.site)
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={dict.meta.description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="ko" href={koUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={koUrl} />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body>
    <Nav locale={locale} />
    <main class="main">
      <slot />
    </main>
  </body>
</html>
